{
  "name": "@workspace/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node --env-file=.env --enable-source-maps ./run-server.mjs",
    "build": "node ./build.mjs",
    "start": "node --env-file=.env --enable-source-maps ./run-server.mjs",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "db:push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "codegen": "orval --config ./api-spec/orval.config.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "multer": "1.4.5-lts.2",
    "mysql2": "^3.22.3",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "esbuild": "0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "orval": "^8.5.2",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0"
  }
}
