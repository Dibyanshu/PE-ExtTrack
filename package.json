{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "backend",
     "frontend",
     "e2e"
  ],
  "scripts": {
    "preinstall": "sh -c 'rm -f yarn.lock'",
    "build": "npm run typecheck && npm run -ws --if-present build",
    "typecheck:libs": "tsc --build",
     "typecheck": "npm run typecheck:libs && npm run -ws --if-present typecheck",
     "e2e": "npm run test --workspace=e2e",
     "e2e:ui": "npm run test:ui --workspace=e2e",
     "e2e:report": "npm run report --workspace=e2e"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
