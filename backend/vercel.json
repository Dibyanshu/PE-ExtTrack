{
  "version": 2,
  "installCommand": "(cd .. && npm ci) && node build.mjs",
  "builds": [
    {
      "src": "dist/api/index.js",
      "use": "@vercel/node@5.3.24",
      "config": { "bundle": false }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
